#!/bin/sh
# Fake `claude` CLI for internal/llm tests. Behavior selected by CLAUDE_FAKE_MODE.
# Records argv and stdin to files named by CLAUDE_FAKE_ARGV_FILE / CLAUDE_FAKE_STDIN_FILE.

if [ -n "$CLAUDE_FAKE_ARGV_FILE" ]; then
	printf '%s' "$*" >"$CLAUDE_FAKE_ARGV_FILE"
fi
if [ -n "$CLAUDE_FAKE_STDIN_FILE" ]; then
	cat >"$CLAUDE_FAKE_STDIN_FILE"
else
	cat >/dev/null
fi

case "$CLAUDE_FAKE_MODE" in
ok)
	printf '%s' '[{"type":"system","subtype":"init"},{"type":"result","subtype":"success","is_error":false,"result":"---\ntitle: Test Page\ntype: source\noriginal: notes/x.pdf\n---\n\n# Test Page\n\nBody text."}]'
	;;
okfenced)
	printf '%s' '[{"type":"result","subtype":"success","is_error":false,"result":"```markdown\n---\ntitle: Test Page\ntype: source\noriginal: notes/x.pdf\n---\n\n# Test Page\n\nBody text.\n```"}]'
	;;
execerr)
	# Observed real-world failure: error_during_execution with exit code 0.
	printf '%s' '[{"type":"result","subtype":"error_during_execution","is_error":true,"result":""}]'
	exit 0
	;;
ratelimit)
	printf '%s\n' 'Error: rate limit exceeded (HTTP 429)' >&2
	exit 1
	;;
garbage)
	printf '%s' 'this is not json at all {'
	;;
sleep)
	sleep 10
	;;
*)
	printf 'fake claude: unknown mode %s\n' "$CLAUDE_FAKE_MODE" >&2
	exit 2
	;;
esac
